# Copy this file to .env and fill in real values. Never commit .env.

# --- Database ---
# Used by the app when running natively (not inside Docker Compose)
DATABASE_URL=postgresql+psycopg2://baseball:baseball@localhost:5432/baseball

# Used by docker-compose.yml to configure the postgres container
POSTGRES_USER=baseball
POSTGRES_PASSWORD=baseball
POSTGRES_DB=baseball

# --- External APIs ---
# The Odds API (https://the-odds-api.com/) - free tier: 500 requests/month
# Leave blank to run the app in "no live odds" mode (odds ingestion is skipped,
# edge-vs-market columns show N/A instead of failing).
ODDS_API_KEY=

# Hard monthly cap enforced against the account-wide free-tier limit above
# (ingestion/api_budget.py) - once (calls this month) >= (limit - buffer),
# every odds call is skipped rather than risking an overage. The buffer
# keeps a few calls in reserve for manual debugging near month-end.
ODDS_API_MONTHLY_LIMIT=500
ODDS_API_SAFETY_BUFFER=50

# OpenWeatherMap (https://openweathermap.org/api) - free tier available
# Leave blank to run in "no weather" mode (weather features fall back to
# park-factor-only defaults).
WEATHER_API_KEY=

# Shared-secret header required by POST /models/retrain. Leave blank in dev
# to disable the check; set a real random value before exposing the API.
ADMIN_API_KEY=

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
# Where the Streamlit dashboard (frontend/) looks for the FastAPI backend.
# docker-compose overrides this to http://api:8000 for the frontend service.
API_BASE_URL=http://localhost:8000
MODEL_REGISTRY_DIR=models/registry
TIMEZONE=America/New_York
